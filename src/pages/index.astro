---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const entries = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const bySection = (section: string) =>
	entries.filter((entry) => entry.id.startsWith(`${section}/`)).slice(0, 3);
---

<PageLayout title="Home">
	<article>
		<p>안녕하세요, <strong>임덕윤</strong>입니다.</p>
		<p>프론트엔드 개발자를 목표로 하되, 백엔드와 AI 등 여러 도메인을 넘나들며 꾸준히 지식을 쌓고 있습니다.</p>
		<hr />
		<h2>Timeline</h2>
		<ul>
			<li>삼성 SSAFY 교육 과정 이수 중 <span class="date">2026-현재</span></li>
			<li>동국대학교 WISE캠퍼스 컴퓨터공학과 졸업 <span class="date">2019-2025</span></li>
			<li>경주 지역문제해결 해커톤 대상 수상 <span class="date">2024</span></li>
			<li>한국관광공사 관광데이터 활용 공모전 장려상 수상 <span class="date">2023</span></li>
		</ul>
		<hr />
		<h2><a href="/blog/notes/">Notes</a></h2>
		<ul>
			{bySection('notes').map((entry) => (
				<li><a href={`/blog/${entry.id}/`}>{entry.data.title}</a></li>
			))}
		</ul>
		<hr />
		<h2><a href="/blog/logs/">Logs</a></h2>
		<ul>
			{bySection('logs').map((entry) => (
				<li><a href={`/blog/${entry.id}/`}>{entry.data.title}</a></li>
			))}
		</ul>
		<hr />
		<h2><a href="/blog/thoughts/">Thoughts</a></h2>
		<ul>
			{bySection('thoughts').map((entry) => (
				<li><a href={`/blog/${entry.id}/`}>{entry.data.title}</a></li>
			))}
		</ul>
	</article>
</PageLayout>
