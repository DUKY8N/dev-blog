---
import '../styles/global.css';

const { title = 'Dev Blog', description = '개발 블로그' } = Astro.props;
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="dark" />
		<meta name="theme-color" media="(prefers-color-scheme: dark)" content="#1e1e2e" />
		<meta name="theme-color" media="(prefers-color-scheme: light)" content="#1e1e2e" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="description" content={description} />
		<link rel="icon" href="/favicon.ico" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} | DukY8n</title>
	</head>
	<body>
		<slot />
	</body>
</html>
